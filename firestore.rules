rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: usuarios
// Document ID: {usuarioId}
// Fields:
//   - nome: string (required)
//   - sobrenome: string (required)
//   - cpf: string (required)
//   - cep: string (optional)
//   - idade: number (optional)
//   - email: string (required)
//   - pontos: number (required, default 0)
//   - ativo: bool (required, default true)
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // isAdmin uses ONLY JWT token claims — zero Firestore reads.
    // Role is set as a custom claim by the backend (server.ts) when a user is created or updated.
    // To fix existing admin users, call POST /api/admin/auth/sync-claims.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "rsaavedr@gmail.com" ||
        request.auth.token.email == "admin@indika.com" ||
        request.auth.token.email == "rjavier.gil@gmail.com" ||
        request.auth.token.role == "admin"
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUsuario(data) {
      return data.keys().hasAll(['uid', 'nome', 'sobrenome', 'cpf', 'email', 'pontos', 'ativo', 'role']) &&
             data.uid is string &&
             data.nome is string && data.nome.size() > 0 &&
             data.sobrenome is string && data.sobrenome.size() > 0 &&
             data.cpf is string &&
             data.email is string &&
             data.pontos is number &&
             data.ativo is bool &&
             data.role in ['admin', 'usuario'];
    }

    function isValidTransacao(data) {
      return data.keys().hasAll(['userId', 'pontos', 'tipo', 'origem', 'descricao', 'createdAt', 'saldoAnterior', 'saldoNovo']) &&
             data.userId is string &&
             data.pontos is number && data.pontos > 0 &&
             data.tipo in ['credito', 'debito'] &&
             data.origem in ['manual', 'campanha', 'bonus', 'resgate'] &&
             data.descricao is string && data.descricao.size() > 0 &&
             data.saldoAnterior is number &&
             data.saldoNovo is number &&
             (!('campanhaId' in data) || data.campanhaId is string) &&
             (!('campanhaNome' in data) || data.campanhaNome is string);
    }

    function isValidCampanha(data) {
      return data.keys().hasAll(['nome', 'descricao', 'status', 'dataInicio', 'dataFim']) &&
             data.nome is string && data.nome.size() > 0 &&
             data.descricao is string &&
             data.status in ['rascunho', 'ativa', 'pausada', 'finalizada', 'inativa'] &&
             data.dataInicio is timestamp &&
             data.dataFim is timestamp;
    }

    match /usuarios/{usuarioId} {
      // Allow read if: doc ID matches auth uid (isOwner),
      // OR the uid field inside the doc matches auth uid (admin-created users),
      // OR the requester is an admin.
      allow read: if isAuthenticated() && (
        isOwner(usuarioId) ||
        resource.data.uid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        (isOwner(usuarioId) && request.resource.data.role == 'usuario') ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        (isOwner(usuarioId) && request.resource.data.role == resource.data.role) ||
        resource.data.uid == request.auth.uid ||
        isAdmin()
      );
    }

    match /transacoes_pontos/{transacaoId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAdmin();
    }

    match /campanhas/{campanhaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Users can register their own participation; admins can update/delete
    match /campaign_participations/{participationId} {
      allow read: if isAuthenticated() &&
        (resource == null || request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admin-only: assign campaigns to specific users
    match /campaign_user_assignments/{assignmentId} {
      allow read: if isAuthenticated() &&
        (resource == null || request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }

    // Missões: all authenticated users can read active missions; only admins write
    match /missoes/{missaoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Mission participations: users can create/read their own; admins can do anything
    match /mission_participations/{participationId} {
      allow read: if isAuthenticated() &&
        (resource == null || request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Faixas config: all authenticated users can read; only admins write
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Notification queue: users create their own; admins read/update
    match /notification_queue/{notifId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // Withdraw requests
    match /withdraw_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
